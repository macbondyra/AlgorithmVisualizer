<Window x:Class="AlgorithmVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AlgorithmVisualizer" 
        xmlns:converters="clr-namespace:AlgorithmVisualizer.Converters"
        Title="Sorting Visualizer Symphonic" Height="750" Width="1200" Background="#121212">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBool"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1E1E1E" Padding="15" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <StackPanel Margin="10,0">
                    <TextBlock Text="ALGORYTM" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Algorithms}" SelectedItem="{Binding SelectedAlgorithm}" Width="160" 
                              IsEnabled="{Binding IsSorting, Converter={StaticResource InverseBool}}"/>
                </StackPanel>

                <StackPanel Margin="15,0" Visibility="{Binding IsMaster, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding DataCount, StringFormat='ELEMENTY: {0}'}" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Slider Minimum="10" Maximum="1000" Value="{Binding DataCount}" Width="110" IsSnapToTickEnabled="True" TickFrequency="10"
                            IsEnabled="{Binding IsSorting, Converter={StaticResource InverseBool}}"/>
                </StackPanel>

                <StackPanel Margin="15,0">
                    <TextBlock Text="{Binding Delay, StringFormat='OPÓŹNIENIE: {0}ms'}" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Slider Minimum="1" Maximum="300" Value="{Binding Delay}" Width="110" IsSnapToTickEnabled="True" TickFrequency="1"/>
                </StackPanel>

                <StackPanel Margin="15,0" VerticalAlignment="Center">
                    <TextBlock Text="DŹWIĘK" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding IsSoundEnabled}" HorizontalAlignment="Center">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                </StackPanel>

                <StackPanel Margin="10,0">
                    <TextBlock Text="KOLOR" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableColors}" SelectedItem="{Binding SelectedColor}" Width="70">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Fill="{Binding}" Width="30" Height="12" RadiusX="2" RadiusY="2"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20,0" Visibility="{Binding IsMaster, Converter={StaticResource BoolToVis}}">
                    <Button Content="GENERUJ" Click="Generate_Click" Width="80" Height="35" Margin="5,0" Background="#333" Foreground="White" BorderThickness="0"/>

                    <Button Content="START" Click="Start_Click" Width="80" Height="35" Margin="5,0" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0"
                            Visibility="{Binding IsSorting, Converter={StaticResource InverseBool}}"/>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsSorting, Converter={StaticResource BoolToVis}}">
                        <Button Content="PAUZA" Click="Pause_Click" Width="80" Height="35" Margin="5,0" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0"
                                Visibility="{Binding IsPaused, Converter={StaticResource InverseBool}}"/>
                        <Button Content="WZNÓW" Click="Start_Click" Width="80" Height="35" Margin="5,0" Background="#D4AC0D" Foreground="White" FontWeight="Bold" BorderThickness="0"
                                Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="15,0" VerticalAlignment="Center">
                    <TextBlock Text="CZAS" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SortTime}" Foreground="#4EC9B0" FontSize="18" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>

                <StackPanel Margin="15,0" VerticalAlignment="Center" Visibility="{Binding IsMaster, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="ROBOTNICY" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ConnectedWorkersCount}" Foreground="#4EC9B0" FontSize="18" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="15,0" VerticalAlignment="Center" Visibility="{Binding IsWorker, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="STATUS ROBOTNIKA" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding WorkerStatus}" Foreground="#D4AC0D" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" VerticalAlignment="Bottom" Margin="10,30">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" VerticalAlignment="Bottom"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Rectangle Height="{Binding Value}" Fill="{Binding Color}" Margin="0,0,1,0"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Nakładka ekranu początkowego -->
        <Grid x:Name="RoleOverlay" Grid.RowSpan="2" Background="#E6121212" Panel.ZIndex="100">
            <Border Background="#1E1E1E" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="WYBIERZ ROLĘ" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    
                    <Button Content="JESTEM MISTRZEM (SERWER)" Click="Master_Click" Width="300" Height="50" Margin="0,5" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0"/>
                    
                    <Button Content="JESTEM ROBOTNIKIEM (KLIENT)" Click="Worker_Click" Width="300" Height="50" Margin="0,15,0,5" Background="#28A745" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0"/>

                    <StackPanel x:Name="WorkerPanel" Visibility="Collapsed" Margin="0,20,0,0">
                        <TextBlock Text="ADRES IP MISTRZA:" Foreground="Gray" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="IpTextBox" Text="127.0.0.1" Width="300" Height="35" FontSize="14" VerticalContentAlignment="Center" Padding="5,0"/>
                        
                        <Button Content="POŁĄCZ" Click="Connect_Click" Width="300" Height="45" Margin="0,15,0,0" Background="#D4AC0D" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>